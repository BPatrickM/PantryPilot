# ─────────────────────────────────────────────
# PantryPilot — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Walmart Open API ──────────────────────────
WALMART_CLIENT_ID=your-walmart-client-id
WALMART_CLIENT_SECRET=your-walmart-client-secret
WALMART_API_BASE=https://api.walmart.com

# ── Redis (BullMQ + session pool) ────────────
REDIS_URL=redis://localhost:6379
# For Upstash (production):
# UPSTASH_REDIS_URL=https://your-db.upstash.io
# UPSTASH_REDIS_TOKEN=your-token

# ── Encryption ────────────────────────────────
# 32-byte hex string — run: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Phase 2 (OCR — not needed for MVP) ───────
# GOOGLE_CLOUD_VISION_API_KEY=your-key
